# .env.example - variáveis de ambiente do projeto (template público)
#
# Uso (uma vez por máquina):
#   cp .env.example .env
#   # editar `.env` com o project_id real
#   source .env
#
# O `.env` real fica no `.gitignore` (nunca comitar valores reais)
#

# Projeto GCP Sandbox onde o pipeline dbt roda
# Coloque o ID do seu projeto GCP Sandbox aqui
DBT_GCP_PROJECT=
